generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id         String   @id @default(uuid())
  name       String   @unique @db.VarChar(50)
  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt
  Users      User[]
}

model User {
  id            String         @id @default(uuid())
  name          String?        @db.VarChar(50)
  email         String         @unique @db.VarChar(50)
  password      String         @db.VarChar(100)
  roleId        String? // Updated to String
  verified      Boolean?       @default(false)
  createdAt     DateTime       @default(now())
  modifiedAt    DateTime       @updatedAt
  orgId         String? // Updated to String
  imgUrl        String?        @db.VarChar(300)
  role          Role?          @relation(fields: [roleId], references: [id])
  ActiveClient  ActiveClient?
  conversations Conversation[]
  ZautoMessages ZautoMessage[]

  @@index([roleId], map: "Users_roleId_fkey")
}

enum VerificationType {
  VERIFYEMAIL
  FORGOTPASSWORD
}

model Verification {
  id         String           @id @default(uuid())
  userId     String // Updated to String
  email      String
  token      String           @default("default") @db.VarChar(100)
  type       VerificationType
  createdAt  DateTime         @default(now())
  modifiedAt DateTime         @updatedAt

  @@index([userId], map: "userId_Verification_fkey")
}

model Organization {
  id         String   @id @default(uuid())
  name       String   @default("default") @db.VarChar(50)
  siteUrl    String?  @db.Text()
  emails     String[]
  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt
}

model ActiveClient {
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  clientId String @unique

  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt

  @@unique([userId, clientId], name: "Unique_userId_clientId")
  @@index([userId], map: "UserId_ActiveClient_fkey")
}

enum ConversationType {
  CALL
  CHAT
}

enum SiteProcessStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AgentStatus {
  TRAINING
  TRAININGFAILED
  ACTIVE
  INACTIVE
  DELETED
}

enum BotPosition {
  BOTTOM_CENTER
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

model Agent {
  id               String           @id @default(uuid())
  name             String?          @unique @db.VarChar(100)
  displayName      String           @db.VarChar(50)
  usetools         Boolean          @default(true)
  role             String?          @db.VarChar(100)
  companyName      String           @db.VarChar(100)
  companyBusiness  String?          @db.Text
  companyValue     String?          @db.Text
  purpouse         String?          @db.Text
  leadInfo         String?          @db.Text
  conversationType ConversationType @default(CHAT)
  logoUrl          String?          @db.Text
  welcomeMsg       String?          @db.Text
  llmModel         String?          @db.VarChar(150)
  useAssistant     Boolean          @default(false)
  assistantId      String?          @db.VarChar(100)
  siteObjUrl       String?          @db.Text
  createdAt        DateTime         @default(now())
  modifiedAt       DateTime         @updatedAt
  status           AgentStatus      @default(TRAINING)
  styles           String?          @db.Text
  autoAnalysis     Boolean          @default(false)
  wakeupTime       Float?           @default(5000)
  position         BotPosition?     @default(BOTTOM_RIGHT)
  AgentPrompt      AgentPrompt[]
  AgentFiles       AgentFile[]
  starters         String?          @db.Text
}

model AgentFile {
  id         String   @id @default(uuid())
  agentId    String // Updated to String
  fileId     String?  @db.VarChar(150)
  path       String?
  fileName   String?
  filePath   String?
  size       Int?
  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId], map: "AgentId_agentFile_fkey")
}

// ... and so on for the remaining models ...

model Site {
  id         String             @id @default(uuid())
  url        String             @db.VarChar(500)
  status     SiteProcessStatus? @default(IN_PROGRESS)
  info       String?            @db.Text
  greeting   String?            @db.Text
  createdAt  DateTime           @default(now())
  modifiedAt DateTime           @updatedAt
}

// Continue this pattern for all models in your schema.
model AgentPrompt {
  id         String   @id @default(uuid())
  agentId    String // Updated to String
  templateId String?
  type       String   @db.VarChar(50)
  text       String   @db.Text
  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Visitor {
  id           String   @id @default(uuid())
  userAgent    String   @db.Text
  infoJson     String   @db.Text
  trackingInfo String?  @db.Text
  ipAddress    String?  @db.VarChar(40)
  score        Float    @default(0.0)
  createdAt    DateTime @default(now())
  modifiedAt   DateTime @updatedAt

  conversations Conversation[]
  visits        Visit[]
}

model Visit {
  id String @id @default(uuid())

  visitorId String
  visitor   Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  count  Int    @default(1)
  source String @default("site") @db.VarChar(50)

  score Float @default(0.0)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt

  conversation             Conversation?
  prospectJourneyActivitys ProspectJourney[]

  @@index([visitorId], map: "Visitor_visitorId_fkey")
  @@index([source], map: "Visitor_source_key")
}

enum ConversationStatus {
  ONLINE
  OFFLINE
}

model Conversation {
  id String @id @default(uuid())

  visitorId String
  visitor   Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  campaignId String?   @db.VarChar(200)
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  visitId String @unique
  visit   Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)

  type             ConversationType
  threadId         String?            @db.VarChar(150)
  messages         ZautoMessage[]
  createdAt        DateTime           @default(now())
  modifiedAt       DateTime           @updatedAt
  summary          String?            @db.Text()
  summaryUpdatedAt DateTime?          @db.Timestamp()
  sentimental      Sentimental?
  suggestions      String?            @db.Text()
  taskList         String?            @db.Text()
  potentialLevel   String?
  status           ConversationStatus @default(OFFLINE)
  socketId         String?            @unique() @db.VarChar(200)
  assigneeId       String?
  assignee         User?              @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  aiSuspended      Boolean            @default(false)
  isEnded          Boolean            @default(false)
  isValid          Boolean            @default(false)

  @@index([assigneeId], map: "assignee_Conversation_fkey")
  @@index([campaignId], map: "campaignId_Conversation_fkey")
  @@index([visitorId], map: "visitorId_Conversation_fkey")
  @@index([visitId], map: "visitId_Conversation_fkey")
}

enum MessageMediaType {
  TEXT
  ACTIVITY
  NAVIGATION
  PAGE_ACTIVITY
  ERROR
  WARNING
}

enum Sentimental {
  POSITIVE
  NEGATIVE
  NUTRAL
}

enum Vote {
  UPVOTE
  DOWNVOTE
}

model ZautoMessage {
  id           String           @id @default(uuid())
  conv         Conversation     @relation(fields: [convId], references: [id], onDelete: Cascade)
  convId       String
  role         String           @db.VarChar(20)
  content      String?          @db.Text()
  activityJson Json?
  type         MessageMediaType @default(TEXT)
  url          String?          @db.VarChar(500)
  vote         Vote?
  feedback     String?          @db.VarChar(256)
  sentimental  Sentimental      @default(NUTRAL)
  sentByHuman  Boolean          @default(false)
  sentById     String?
  sentBy       User?            @relation(fields: [sentById], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt

  @@index([convId], map: "convId_ZautoMessage_fkey")
  @@index([sentById], map: "sentById_ZautoMessage_fkey")
}

enum CampaignStatus {
  ACTIVE
  INACTIVE
}

model Campaign {
  id            String         @id @default(uuid())
  hash          String?
  title         String         @db.VarChar(50)
  description   String         @db.Text
  source        String?
  url           String?        @db.Text
  isZauto       Boolean        @default(true)
  idParam       String?
  idValue       String?
  isDefault     Boolean        @default(false)
  isPaied       Boolean        @default(false)
  status        CampaignStatus @default(ACTIVE)
  startDate     DateTime       @default(now())
  endDate       DateTime?      @db.Timestamp()
  accountId     String?
  createdAt     DateTime       @default(now())
  modifiedAt    DateTime       @updatedAt
  Conversations Conversation[]
  Visits        Visit[]
}

model Stage {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  instruction String   @db.Text
  sequence    Int      @unique @db.Integer()
  canEdit     Boolean  @default(true)
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @updatedAt
}

model OpenAIAssistant {
  id           String   @id @default(uuid())
  assistantId  String   @unique
  name         String   @unique @db.VarChar(100)
  description  String   @db.VarChar(256)
  instructions String   @db.Text()
  createdAt    DateTime @default(now())
  modifiedAt   DateTime @updatedAt
}

model OrgSMTPConfig {
  id         String   @id @default(uuid())
  host       String
  port       Int
  name       String
  user       String
  pass       String
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt
}

enum CTAType {
  CTA
  NAVIGATOR
  CALENDAR
}

model CallToAction {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String   @db.VarChar(256)
  link        String?  @db.Text
  type        CTAType? @default(NAVIGATOR)
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @updatedAt
}

model AvailabilitySchedule {
  id             String           @id @default(uuid())
  availableDays  String           @db.Text
  eventDuration  Int
  calendarId     String?          @db.Text
  createdAt      DateTime         @default(now())
  modifiedAt     DateTime         @updatedAt
  availableHours availableHours[]
}

model availableHours {
  id         String   @id @default(uuid())
  start      String
  end        String
  scheduleId String
  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt

  AvailabilitySchedule AvailabilitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model ExternalToolCredential {
  id           String   @id @default(uuid())
  tokenType    String?
  refreshToken String
  accessToken  String
  expiresIn    Int
  toolName     String
  createdAt    DateTime @default(now())
  modifiedAt   DateTime @updatedAt
}

enum ProspectActivityType {
  CTA_PERFORMED
  PAGE_VIEWED
  PAGE_CLOSED
  LINK_CLICKED
  CHAT_INITIATED
  OTHER
}

model ProspectJourney {
  id             String               @id @default(uuid())
  visitId        String
  data           String?
  url            String
  type           ProspectActivityType @default(OTHER)
  timeSpend      Int                  @default(0)
  scrollDepth    Float                @default(0.0)
  previousPageId String?
  previousPage   ProspectJourney?     @relation("PreviousPageRelation", fields: [previousPageId], references: [id])
  nextPages      ProspectJourney[]    @relation("PreviousPageRelation")
  createdAt      DateTime             @default(now())
  modifiedAt     DateTime             @updatedAt
  visit          Visit                @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId, type])
  @@index([previousPageId])
}

enum IntentType {
  POSITIVE
  NEGATIVE
}

model IntentScoring {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  value       Float      @default(0.0)
  type        IntentType
  createdAt   DateTime   @default(now())
  modifiedAt  DateTime   @updatedAt
}

# Build stage
FROM ghcr.io/zautoai/node:20-builder AS builder

# Copy the rest of your source code
COPY . .

# Build your application
RUN npm run build:prod
RUN npm install -g npx --force

# Production stage
FROM ghcr.io/zautoai/node:20-alpine-prod

# Set NODE_ENV to development (or production based on your environment)
ENV NODE_ENV=prod

# Define arguments for environment variables.
ARG APOLLO_API_KEY
ARG AWS_ACCESS_KEY_ID
ARG AWS_REGION
ARG AWS_SECRET_ACCESS_KEY
ARG CHROMA_AUTH_CREDENTIALS
ARG CHROMA_AUTH_PROVIDER
ARG CHROMA_URL
ARG CHUNCK_SIZE
ARG CLAUDE_API_KEY
ARG COHERE_API_KEY
ARG CONVERTO_EMAIL
ARG CONVERTO_TRAIN_BUCKET_NAME
ARG CONVERTO_PIC_BUCKET_NAME
ARG CRYPTO_ENCRYPTION_SECRET
ARG DATABASE_URL_BASE
ARG EMBEDDING_PROVIDER
ARG GOOGLE_CLIENT_ID
ARG HOST_PORT
ARG HOST_URL
ARG IP_DATA_KEY
ARG JWT_SECRET
ARG LLM_PROVIDER
ARG MAX_SMTP_CONNECTIONS
ARG MAX_TOTAL_FILE_SIZE
ARG NODE_secrets
ARG OPENAI_API_KEY
ARG OPENAI_ASSISTANT_DEFAULT_MODEL
ARG OPEN_AI_EMBEDDING_MODEL
ARG OPEN_AI_MODEL
ARG QUICK_MAIL_VALIDATOR_API
ARG REDIS_IP
ARG REDIS_PASSWORD
ARG REDIS_PORT
ARG SENDGRID_KEY
ARG SIGNUP_ALERT_MAIL
ARG SUPER_USER_EMAIL
ARG SUPER_USER
ARG SUPER_USER_PASSWORD
ARG TRAINING_CONTENT_PATH
ARG UPLOADS_FOLDER
ARG VERIFICATION_EXPIRES_IN
# Set environment variables from arguments
ENV APOLLO_API_KEY=${APOLLO_API_KEY}
ENV AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
ENV AWS_REGION=${AWS_REGION}
ENV AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
ENV CHROMA_AUTH_CREDENTIALS=${CHROMA_AUTH_CREDENTIALS}
ENV CHROMA_AUTH_PROVIDER=${CHROMA_AUTH_PROVIDER}
ENV CHROMA_URL=${CHROMA_URL}
ENV CHUNCK_SIZE=${CHUNCK_SIZE}
ENV CLAUDE_API_KEY=${CLAUDE_API_KEY}
ENV COHERE_API_KEY=${COHERE_API_KEY}
ENV CONVERTO_EMAIL=${CONVERTO_EMAIL}
ENV CONVERTO_TRAIN_BUCKET_NAME=${CONVERTO_TRAIN_BUCKET_NAME}
ENV CONVERTO_PIC_BUCKET_NAME=${COVERTO_PIC_BUCKET_NAME}
ENV CRYPTO_ENCRYPTION_SECRET=${CRYPTO_ENCRYPTION_SECRET}
ENV DATABASE_URL_BASE=${DATABASE_URL_BASE}
ENV EMBEDDING_PROVIDER=${EMBEDDING_PROVIDER}
ENV GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
ENV HOST_PORT=${HOST_PORT}
ENV HOST_URL=${HOST_URL}
ENV IP_DATA_KEY=${IP_DATA_KEY}
ENV JWT_SECRET=${JWT_SECRET}
ENV LLM_PROVIDER=${LLM_PROVIDER}
ENV MAX_SMTP_CONNECTIONS=${MAX_SMTP_CONNECTIONS}
ENV MAX_TOTAL_FILE_SIZE=${MAX_TOTAL_FILE_SIZE}
ENV NODE_secrets=${NODE_secrets}
ENV OPENAI_API_KEY=${OPENAI_API_KEY}
ENV OPENAI_ASSISTANT_DEFAULT_MODEL=${OPENAI_ASSISTANT_DEFAULT_MODEL}
ENV OPEN_AI_EMBEDDING_MODEL=${OPEN_AI_EMBEDDING_MODEL}
ENV OPEN_AI_MODEL=${OPEN_AI_MODEL}
ENV QUICK_MAIL_VALIDATOR_API=${QUICK_MAIL_VALIDATOR_API}
ENV REDIS_IP=${REDIS_IP}
ENV REDIS_PASSWORD=${REDIS_PASSWORD}
ENV REDIS_PORT=${REDIS_PORT}
ENV SENDGRID_KEY=${SENDGRID_KEY}
ENV SIGNUP_ALERT_MAIL=${SIGNUP_ALERT_MAIL}
ENV SUPER_USER_EMAIL=${SUPER_USER_EMAIL}
ENV SUPER_USER=${SUPER_USER}
ENV SUPER_USER_PASSWORD=${SUPER_USER_PASSWORD}
ENV TRAINING_CONTENT_PATH=${TRAINING_CONTENT_PATH}
ENV UPLOADS_FOLDER=${UPLOADS_FOLDER}
ENV VERIFICATION_EXPIRES_IN=${VERIFICATION_EXPIRES_IN}


# Only copy over the built elements from the dist folder from the previous stage
COPY --from=builder /usr/src/app/node_modules ./node_modules
COPY --from=builder /usr/src/app/dist ./
COPY --from=builder /usr/src/app/prisma ./prisma
COPY --from=builder /usr/src/app/public/ ../public

RUN npx prisma generate

WORKDIR /usr/src/

# Expose the port the app runs on
EXPOSE 3000

# Start the app
CMD [ "node", "app/main.js" ]

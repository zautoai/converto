{
  "name": "zauto_be",
  "version": "0.0.1",
  "description": "",
  "author": "Zauto Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:client": "cd client && npm install --force && npm run build",
    "build:client:dev": "cd client && npm install --force && npm run build:dev",
    "build:client:prod": "cd client && npm install --force && npm run build:prod",
    "build:client:stage": "cd client && npm install --force && npm run build:stage",
    "build:client:test": "cd client && npm install --force && npm run build:test",
    "copy:zautobot": "mkdir -p public/zautobot && cp -rf zautobot/* public/zautobot",
    "copy:client": "mkdir -p public && cp -rf client/dist/preview/* public/",
    "build:dev": "nest build && npm run build:client:dev && npm run copy:client && npm run copy:zautobot",
    "build:prod": "nest build && npm run build:client:prod && npm run copy:client && npm run copy:zautobot",
    "build:stage": "nest build && npm run build:client:stage && npm run copy:client && npm run copy:zautobot",
    "build:test": "nest build && npm run build:client:test && npm run copy:client && npm run copy:zautobot",
    "build": "nest build && npm run build:client && npm run copy:client && npm run copy:zautobot",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db-push": "npx prisma db push"
  },
  "resolutions": {
    "got": "11.8.2"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@hubspot/api-client": "^11.1.0",
    "@mistralai/mistralai": "^0.1.3",
